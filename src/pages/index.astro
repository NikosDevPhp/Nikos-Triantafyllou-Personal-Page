---
import Base from "../layouts/Base.astro";
---

<Base title="Nikos Triantafyllou — Developer" active="home">
  <main id="top">
    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero__grid" aria-hidden="true"></div>
      <div class="hero__inner">
        <p class="hero__eyebrow">
          <span class="blink">▍</span> Hello world, I'm
        </p>
        <h1 class="hero__title">
          Nikos
          <span class="hero__title-accent">Triantafyllou</span>
        </h1>
        <p class="hero__role">
          Software Developer &nbsp;·&nbsp; building the web with care
        </p>
        <p class="hero__lede">
          I design and ship clean, dependable software — from tidy back-ends
          to interfaces that feel good to use. Old-school craft, modern tools.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="#work">See my work</a>
          <a class="btn btn--ghost" href="#contact">Get in touch</a>
        </div>

        <ul class="hero__facts">
          <li><strong>07+</strong><span>years shipping</span></li>
          <li><strong>PHP</strong><span>&amp; friends</span></li>
          <li><strong>GR</strong><span>based · remote</span></li>
        </ul>
      </div>

      <div class="hero__terminal" aria-hidden="true">
        <div class="term__bar">
          <span></span><span></span><span></span>
          <p class="term__title">~/nikos — zsh</p>
        </div>
        <pre class="term__body"><span class="c-dim">$</span> whoami
<span class="c-out">nikos — developer, tinkerer, coffee-driven</span>
<span class="c-dim">$</span> cat stack.txt
<span class="c-out">php · laravel · js · sql · docker · git</span>
<span class="c-dim">$</span> ./say-hello --to=you
<span class="c-acc">Welcome. Scroll on. →</span>
<span class="c-dim">$</span> <span class="blink">▍</span></pre>
      </div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section id="about" class="section">
      <div class="section__head">
        <span class="section__no">01</span>
        <h2 class="section__title">About</h2>
        <span class="section__rule" aria-hidden="true"></span>
      </div>
      <div class="about">
        <div class="about__text">
          <p>
            I'm a software developer who likes things <em>well built</em>: readable code,
            sensible architecture, and interfaces that respect the person using them.
          </p>
          <p>
            My background leans toward the back-end — designing data models, writing
            APIs, and keeping systems reliable — but I enjoy the full journey from
            an empty file to something people actually use.
          </p>
          <p>
            When I'm away from the keyboard you'll usually find me chasing good coffee,
            reading, or poking at some side project that probably didn't need to exist.
          </p>
        </div>
        <aside class="about__card">
          <h3>At a glance</h3>
          <dl>
            <div><dt>Role</dt><dd>Software Developer</dd></div>
            <div><dt>Focus</dt><dd>Back-end · Web</dd></div>
            <div><dt>Location</dt><dd>Greece · Remote</dd></div>
            <div><dt>Status</dt><dd><span class="dot dot--live"></span>Open to chat</dd></div>
          </dl>
        </aside>
      </div>
    </section>

    <!-- ===== STACK ===== -->
    <section id="stack" class="section">
      <div class="section__head">
        <span class="section__no">02</span>
        <h2 class="section__title">Stack</h2>
        <span class="section__rule" aria-hidden="true"></span>
      </div>
      <ul class="stack">
        <li class="stack__item"><span class="stack__key">Languages</span>PHP · JavaScript · SQL</li>
        <li class="stack__item"><span class="stack__key">Frameworks</span>Laravel · Symfony · Node</li>
        <li class="stack__item"><span class="stack__key">Front-end</span>HTML · CSS · Vanilla JS</li>
        <li class="stack__item"><span class="stack__key">Data</span>MySQL · PostgreSQL · Redis</li>
        <li class="stack__item"><span class="stack__key">Tooling</span>Git · Docker · CI/CD</li>
        <li class="stack__item"><span class="stack__key">Practice</span>Testing · Clean code · Reviews</li>
      </ul>
    </section>

    <!-- ===== WORK ===== -->
    <section id="work" class="section">
      <div class="section__head">
        <span class="section__no">03</span>
        <h2 class="section__title">Selected Work</h2>
        <span class="section__rule" aria-hidden="true"></span>
      </div>
      <p class="section__note">A few placeholders — real case studies coming soon.</p>
      <div class="work">
        <article class="card">
          <header class="card__top">
            <span class="card__tag">Web App</span>
            <span class="card__year">2025</span>
          </header>
          <h3 class="card__title">Ledger &amp; Reports</h3>
          <p class="card__desc">A back-office tool for tracking transactions with exportable, human-friendly reports.</p>
          <ul class="card__stack"><li>Laravel</li><li>MySQL</li><li>Charts</li></ul>
        </article>
        <article class="card">
          <header class="card__top">
            <span class="card__tag">API</span>
            <span class="card__year">2024</span>
          </header>
          <h3 class="card__title">Service Gateway</h3>
          <p class="card__desc">A tidy REST layer with auth, rate-limiting and clear docs sitting in front of legacy services.</p>
          <ul class="card__stack"><li>PHP</li><li>Redis</li><li>OpenAPI</li></ul>
        </article>
        <article class="card">
          <header class="card__top">
            <span class="card__tag">Side Project</span>
            <span class="card__year">2023</span>
          </header>
          <h3 class="card__title">This Very Page</h3>
          <p class="card__desc">A retro-modern personal site, built with Astro and hosted on GitHub Pages.</p>
          <ul class="card__stack"><li>Astro</li><li>TypeScript</li><li>Markdown</li></ul>
        </article>
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section id="contact" class="section section--contact">
      <div class="section__head">
        <span class="section__no">04</span>
        <h2 class="section__title">Say hello</h2>
        <span class="section__rule" aria-hidden="true"></span>
      </div>
      <div class="contact">
        <p class="contact__lede">
          Got a project, a question, or just want to talk shop?
          My inbox is always open.
        </p>
        <a class="btn btn--primary btn--big" href="mailto:niktriant89@gmail.com">niktriant89@gmail.com</a>
        <div class="contact__links">
          <a href="https://github.com/NikosDevPhp" target="_blank" rel="noopener">GitHub ↗</a>
          <a href="mailto:niktriant89@gmail.com">Email ↗</a>
        </div>
      </div>
    </section>
  </main>
</Base>
